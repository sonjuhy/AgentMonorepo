# 베이스 이미지: 반드시 python:3.X-alpine 사용 (slim 금지)
FROM python:3.12-alpine

# 에이전트 실행 작업 디렉토리 설정
WORKDIR /app

# (선택) 시스템 종속성이 필요하다면 apk 활용
# RUN apk add --no-cache ...

# 모노리포 구조: 패키지 인식을 위해 __init__.py를 포함하여 복사
COPY ./agents/__init__.py /app/agents/__init__.py
COPY ./shared_core /app/shared_core
COPY ./agents/archive_agent /app/agents/archive_agent

# requirements 등 파이썬 의존성 설치
RUN pip install --no-cache-dir -r /app/agents/archive_agent/requirements.txt

# 파이썬 모듈 경로 설정
ENV PYTHONPATH=/app

# 진입점 설정: 데몬 또는 무한 대기 상태가 아닌, 단일 스크립트 실행 후 즉시 종료되도록 구성
CMD ["python", "-m", "agents.archive_agent.main"]
