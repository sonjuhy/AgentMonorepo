# 베이스 이미지: 반드시 python:3.X-alpine 사용 (slim 금지)
FROM python:3.12-alpine

# 에이전트 실행 작업 디렉토리 설정
WORKDIR /app

# 모노리포 구조: 패키지 인식을 위해 __init__.py를 포함하여 복사
COPY ./agents/__init__.py /app/agents/__init__.py
COPY ./shared_core /app/shared_core
COPY ./agents/communication_agent /app/agents/communication_agent

# 파이썬 의존성 설치 환경 구성
RUN pip install --no-cache-dir -r /app/agents/communication_agent/requirements.txt

# 파이썬 모듈 경로 설정
ENV PYTHONPATH=/app

# 진입점 설정: 데몬 또는 무한 대기 상태가 아닌, 단일 스크립트 실행 후 즉시 종료
CMD ["python", "-m", "agents.communication_agent.main"]
