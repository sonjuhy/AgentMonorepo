# Slack Agent FastAPI 서버 (장기 실행 Socket Mode 리스너)
# - FastAPI + uvicorn + slack_sdk Socket Mode 기반
# - docker run 으로 에이전트 컨테이너를 트리거하므로 docker-cli 포함
FROM python:3.12-alpine

# docker CLI 설치 (에이전트 컨테이너 실행용) + 빌드 도구
RUN apk add --no-cache docker-cli gcc musl-dev libffi-dev

WORKDIR /app

# 모노리포 구조: 필요한 모듈만 복사
COPY ./agents/__init__.py /app/agents/__init__.py
COPY ./agents/slack_agent /app/agents/slack_agent

# 의존성 설치
RUN pip install --no-cache-dir -r /app/agents/slack_agent/requirements.txt

# FastAPI 헬스체크 포트
EXPOSE 8000

# 진입점: uvicorn 으로 FastAPI 앱 실행 (Socket Mode 자동 시작)
CMD ["python", "/app/agents/slack_agent/listener_main.py"]
